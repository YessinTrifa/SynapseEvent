<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane
        styleClass="login-bg"
        stylesheets="@../css/auth.css"
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.synapseevent.controller.RegisterController">

    <!-- Centered card -->
    <VBox maxWidth="520"
          StackPane.alignment="CENTER"
          styleClass="login-right-panel"
          spacing="16"
          style="-fx-background-radius: 24;
                 -fx-border-radius: 24;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 32, 0, 0, 8);">

        <!-- Title -->
        <Label text="Sign Up"
               styleClass="login-form-title"
               maxWidth="9999"
               style="-fx-alignment: center; -fx-text-alignment: center;" />

        <Region prefHeight="4" />

        <!-- FORM -->
        <GridPane hgap="12" vgap="10" maxWidth="9999">
            <columnConstraints>
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS" />
                <ColumnConstraints percentWidth="50" hgrow="ALWAYS" />
            </columnConstraints>

            <!-- Row 0: Name | Last name -->
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Name" styleClass="login-label" />
                <TextField fx:id="prenomField"
                           promptText="Name"
                           styleClass="login-pill-field" />
                <Label fx:id="prenomError"
                       styleClass="reg-error"
                       visible="false" managed="false" />
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Last name" styleClass="login-label" />
                <TextField fx:id="nomField"
                           promptText="Last name"
                           styleClass="login-pill-field" />
                <Label fx:id="nomError"
                       styleClass="reg-error"
                       visible="false" managed="false" />
            </VBox>

            <!-- Row 1: Email full width -->
            <VBox spacing="4"
                  GridPane.columnIndex="0" GridPane.rowIndex="1"
                  GridPane.columnSpan="2">
                <Label text="Email" styleClass="login-label" />
                <TextField fx:id="emailField"
                           promptText="email"
                           styleClass="login-pill-field"
                           maxWidth="9999" />
                <Label fx:id="emailError"
                       styleClass="reg-error"
                       visible="false" managed="false" />
            </VBox>

            <!-- Row 2: Password | Confirm Password -->
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Password" styleClass="login-label" />
                <PasswordField fx:id="passwordField"
                               promptText="............"
                               styleClass="login-pill-field" />
                <Label fx:id="passwordError"
                       styleClass="reg-error"
                       visible="false" managed="false" />
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <Label text="Confirm Password" styleClass="login-label" />
                <PasswordField fx:id="confirmPasswordField"
                               promptText="............"
                               styleClass="login-pill-field" />
                <Label fx:id="confirmPasswordError"
                       styleClass="reg-error"
                       visible="false" managed="false" />
            </VBox>

            <!-- Row 3: Phone | Address -->
            <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <Label text="Phone (optional)" styleClass="login-label" />
                <TextField fx:id="phoneField"
                           promptText="phone"
                           styleClass="login-pill-field" />
                <Label fx:id="phoneError"
                       styleClass="reg-error"
                       visible="false" managed="false" />
            </VBox>

            <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="3">
                <Label text="Address (optional)" styleClass="login-label" />
                <TextField fx:id="addressField"
                           promptText="address"
                           styleClass="login-pill-field" />
            </VBox>

        </GridPane>

        <!-- Entreprise row -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #eff6ff;
                     -fx-border-color: #3b82f6;
                     -fx-border-width: 1.5;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 10 16 10 16;">
            <Label text="Entreprise" styleClass="login-label"
                   style="-fx-font-size: 13px; -fx-font-weight: 800;"
                   HBox.hgrow="NEVER" />
            <Region HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="entrepriseCombo"
                      promptText="Select"
                      minWidth="180"
                      prefWidth="220"
                      prefHeight="38" />
        </HBox>

        <!-- Hidden boxes for controller logic -->
        <VBox fx:id="existingEnterpriseBox" visible="false" managed="false" />
        <VBox fx:id="newEnterpriseBox" visible="false" managed="false">
            <TextField fx:id="entrepriseNameField" />
            <TextField fx:id="entrepriseSiretField" />
            <Label fx:id="siretError" visible="false" managed="false" />
        </VBox>

        <!-- Feedback message -->
        <Label fx:id="messageLabel"
               styleClass="reg-message"
               wrapText="true"
               maxWidth="9999" />

        <!-- Create Account button -->
        <Button text="Create Account"
                defaultButton="true"
                onAction="#registerUser"
                styleClass="login-primary-btn"
                maxWidth="9999" />

        <!-- Already have account -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Already have an account?" styleClass="login-label" />
            <Button text="Login"
                    styleClass="login-create-link"
                    onAction="#goToLogin" />
        </HBox>

    </VBox>
</StackPane>