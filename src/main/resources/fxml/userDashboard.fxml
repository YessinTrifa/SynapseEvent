<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="page-wrap" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.synapseevent.controller.UserDashboardController">
    <stylesheets>
        <URL value="@../css/dashboard.css" />
    </stylesheets>
    <!-- MAIN PAGE CONTENT (your dark web layout) -->
    <VBox spacing="0" VBox.vgrow="ALWAYS">


        <!-- Main TabPane -->
        <HBox VBox.vgrow="ALWAYS">

            <!-- SIDEBAR -->
            <VBox styleClass="user-sidebar" spacing="0" VBox.vgrow="ALWAYS">

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-padding: 16 12 14 12;
                     -fx-border-color: rgba(255,255,255,0.12);
                     -fx-border-width: 0 0 1 0;">
                    <ImageView fitHeight="90.0" fitWidth="102.0" nodeOrientation="RIGHT_TO_LEFT" preserveRatio="true">
                        <image>
                            <Image url="@../images/logo.png" />
                        </image>
                    </ImageView>
                </HBox>

                <Region prefHeight="10" />

                <!-- Nav buttons -->
                <Button fx:id="userNavHome"     styleClass="user-nav-btn" text="🏠  Home"            maxWidth="9999" onAction="#showUserHome" />
                <Button fx:id="userNavBrowse"   styleClass="user-nav-btn" text="🔍  Browse By Type"  maxWidth="9999" onAction="#showUserBrowse" />
                <Button fx:id="userNavBookings" styleClass="user-nav-btn" text="📋  My Booking"      maxWidth="9999" onAction="#showUserBookings" />
                <Button fx:id="userNavCalendar" styleClass="user-nav-btn" text="📅  Calendar"        maxWidth="9999" onAction="#showGlobalCalendar" />
                <Button fx:id="userNavRequests" styleClass="user-nav-btn" text="✨  Custom Requests" maxWidth="9999" onAction="#showUserRequests" />
                <Button fx:id="userNavProfile"  styleClass="user-nav-btn" text="👤  Profile"         maxWidth="9999" onAction="#showUserProfile" />

                <Region VBox.vgrow="ALWAYS" />

                <Button onAction="#logout"
                        styleClass="user-nav-logout"
                        text="🚪  Logout"
                        maxWidth="9999" />
            </VBox>

            <!-- MAIN CONTENT -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">

                <!-- Top bar: title + buttons -->
                <HBox alignment="CENTER_LEFT" spacing="14"
                      style="-fx-padding: 12 24 12 24; -fx-background-color: transparent;">
                    <Label fx:id="userTopTitle" styleClass="user-top-title" text="Home" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="backToAdminBtn" onAction="#goToAdminDashboard"
                            styleClass="user-btn-secondary" text="Admin View" />

                </HBox>

                <!-- Scrollable content area -->
                <ScrollPane fitToWidth="true" fitToHeight="false"
                            hbarPolicy="NEVER" vbarPolicy="NEVER"
                            styleClass="user-scroll"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="0">

                            <!-- PAGE: Home -->
                            <VBox fx:id="userPageHome" spacing="16" visible="true" managed="true"
                                  style="-fx-padding: 16 24 24 24; -fx-background-color: transparent;">

                                <!-- Quick Picks -->
                                <VBox spacing="8">
                                    <Label styleClass="user-section-title" text="Quick Picks" />
                                    <HBox fx:id="quickRecommendationsBox" spacing="10" style="-fx-flex-wrap: wrap;">
                                        <Button onAction="#showRecommendedByLocation"  styleClass="user-chip-red"    text="Anniverssaire" />
                                        <Button onAction="#showRecommendedFormation"   styleClass="user-chip-maroon" text="Formation" />
                                        <Button onAction="#showRecommendedBeach"       styleClass="user-chip-teal"   text="Paddel" />
                                        <Button onAction="#showRecommendedTeamBuilding" styleClass="user-chip-orange" text="Team buikding" />
                                    </HBox>
                                </VBox>

                                <!-- Filter bar -->
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="user-filter-bar">
                                    <Label styleClass="user-filter-label" text="VENUE" />
                                    <ComboBox fx:id="locationFilterCombo" styleClass="user-combo" prefWidth="100" />
                                    <Label styleClass="user-filter-label" text="TYPE" />
                                    <ComboBox fx:id="typeFilterCombo" styleClass="user-combo" prefWidth="100" />
                                    <Label styleClass="user-filter-label" text="FROM" />
                                    <DatePicker fx:id="dateFromPicker" styleClass="user-datepicker" prefWidth="130" />
                                    <Label styleClass="user-filter-label" text="TO" />
                                    <DatePicker fx:id="dateToPicker" styleClass="user-datepicker" prefWidth="130" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button onAction="#applyFilters" text="Apply"
                                            style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 12px; -fx-padding: 7 20; -fx-background-radius: 10; -fx-border-color: transparent; -fx-border-width: 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 8, 0, 0, 3);" />
                                    <Button onAction="#clearFilters" text="Clear"
                                            style="-fx-background-color: rgba(255,255,255,0.70); -fx-text-fill: #1e40af; -fx-font-weight: 700; -fx-font-size: 12px; -fx-padding: 7 20; -fx-background-radius: 10; -fx-border-color: transparent; -fx-border-width: 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);" />
                                </HBox>

                                <!-- All Available Events (full width, on top) -->
                                <VBox spacing="8" styleClass="user-card">
                                    <Label styleClass="user-section-title" text="All Available Events" />
                                    <TableView fx:id="allEventsTable" prefHeight="220" styleClass="user-table">
                                        <columns>
                                            <TableColumn fx:id="allNameColumn"     text="Name"     />
                                            <TableColumn fx:id="allTypeColumn"     text="Type"     />
                                            <TableColumn fx:id="allDateColumn"     text="Date"     />
                                            <TableColumn fx:id="allLocationColumn" text="Location" />
                                            <TableColumn fx:id="allPriceColumn"    text="Price"    />
                                            <TableColumn fx:id="allStatusColumn"   text="Status"   />
                                            <TableColumn fx:id="allActionColumn"   text="Book"     />
                                        </columns>
                                    </TableView>
                                </VBox>

                                <!-- Featured + Recommended SIDE BY SIDE -->
                                <HBox spacing="16">

                                    <!-- Featured Events -->
                                    <VBox spacing="8" styleClass="user-card" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-section-title" text="Featured events" />
                                        <TableView fx:id="featuredEventsTable" prefHeight="180" styleClass="user-table">
                                            <columns>
                                                <TableColumn fx:id="featuredNameColumn"     text="Name"     />
                                                <TableColumn fx:id="featuredTypeColumn"     text="Type"     />
                                                <TableColumn fx:id="featuredDateColumn"     text="Date"     />
                                                <TableColumn fx:id="featuredLocationColumn" text="Location" />
                                                <TableColumn fx:id="featuredPriceColumn"    text="Price"    />
                                                <TableColumn fx:id="featuredActionColumn"   text="Book"     prefWidth="80" />
                                            </columns>
                                        </TableView>
                                    </VBox>

                                    <!-- Recommended For You -->
                                    <VBox spacing="8" styleClass="user-card" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-section-title" text="Reccomended for you" />
                                        <TableView fx:id="recommendedEventsTable" prefHeight="180" styleClass="user-table">
                                            <columns>
                                                <TableColumn fx:id="recommendedNameColumn"     text="Name"  />
                                                <TableColumn fx:id="recommendedTypeColumn"     text="Type"  />
                                                <TableColumn fx:id="recommendedDateColumn"     text="Date"  />
                                                <TableColumn fx:id="recommendedLocationColumn" text="Location" />
                                                <TableColumn fx:id="recommendedPriceColumn"    text="Price" />
                                                <TableColumn fx:id="recommendedMatchColumn"    text="Match %" />
                                                <TableColumn fx:id="recommendedActionColumn"   text="Book"  />
                                            </columns>
                                        </TableView>
                                    </VBox>

                                </HBox>

                            </VBox>

                            <!-- PAGE: Browse By Type -->
                            <!-- PAGE: Browse By Type -->
                            <HBox fx:id="userPageBrowse" spacing="16" visible="false" managed="false"
                                  style="-fx-background-color: transparent; -fx-padding: 16 24 24 24;">

                                <!-- Left: Categories panel -->
                                <VBox fx:id="userPageBrowsePanel" prefWidth="200" spacing="8"
                                      style="-fx-background-color: rgba(255,255,255,0.55); -fx-background-radius: 14; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                                    <Label styleClass="user-section-title" text="Categories" />
                                    <Button onAction="#showAllCategoryEvents"  text="All Events"    maxWidth="9999"
                                            style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI'; -fx-font-weight: 600; -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" />
                                    <Button onAction="#showPartyingEvents"     text="Partying"      maxWidth="9999"
                                            style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI'; -fx-font-weight: 600; -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" />
                                    <Button onAction="#showPaddleEvents"       text="Paddle"        maxWidth="9999"
                                            style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI'; -fx-font-weight: 600; -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" />
                                    <Button onAction="#showTeamBuildingEvents" text="Team Building" maxWidth="9999"
                                            style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI'; -fx-font-weight: 600; -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" />
                                    <Button onAction="#showFormationEvents"    text="Formation"     maxWidth="9999"
                                            style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI'; -fx-font-weight: 600; -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" />
                                    <Button onAction="#showAnniversaryEvents"  text="Anniversary"   maxWidth="9999"
                                            style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI'; -fx-font-weight: 600; -fx-font-size: 13px; -fx-padding: 10 14; -fx-background-radius: 10; -fx-border-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;" />
                                </VBox>

                                <!-- Right: Cards area -->
                                <VBox spacing="14" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent;">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label fx:id="categoryTitleLabel" styleClass="user-section-title" text="All Events" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="categoryEventCountLabel" styleClass="user-muted" text="0 events found" />
                                    </HBox>
                                    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS"
                                                style="-fx-background-color: white; -fx-background: white; -fx-border-color: transparent; -fx-background-radius: 14;">
                                        <FlowPane fx:id="eventCardsFlowPane" hgap="20" vgap="20"
                                                  style="-fx-padding: 16; -fx-background-color: white; -fx-min-height: 400;" />
                                    </ScrollPane>
                                </VBox>

                            </HBox>

                            <!-- PAGE: My Bookings -->
                            <VBox fx:id="userPageBookings" spacing="14" visible="false" managed="false"
                                  style="-fx-background-color: transparent; -fx-padding: 16 24 24 24;">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <Label styleClass="user-section-title" text="My Booking History" />
                                    <Region HBox.hgrow="ALWAYS" />
                                </HBox>
                                <TableView fx:id="bookingsTable" styleClass="user-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="bookingTypeColumn"    text="Event Name"    />
                                        <TableColumn fx:id="bookingEventIdColumn" text="Event ID"      />
                                        <TableColumn fx:id="bookingDateColumn"    text="Booking Date"  />
                                        <TableColumn fx:id="bookingStatusColumn"  text="Status"        />
                                        <TableColumn fx:id="bookingRatingColumn"  text="Avg Rating"    prefWidth="100" />
                                        <TableColumn fx:id="bookingActionColumn"  text="Action"        prefWidth="100" />
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- PAGE: Custom Requests -->
                            <VBox fx:id="userPageRequests" spacing="16" visible="false" managed="false"
                                  style="-fx-background-color: transparent; -fx-padding: 16 24 24 24;">
                                <Label styleClass="user-section-title" text="Create Custom Event Request" />

                                <HBox spacing="14">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-form-label" text="Event Type:" />
                                        <ComboBox fx:id="eventTypeCombo" styleClass="user-combo" maxWidth="9999" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-form-label" text="Event Date:" />
                                        <DatePicker fx:id="eventDatePicker" styleClass="user-datepicker" maxWidth="9999" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-form-label" text="Budget (TND):" />
                                        <TextField fx:id="budgetField" promptText="Enter budget" styleClass="user-input" />
                                    </VBox>
                                </HBox>

                                <HBox spacing="14">
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-form-label" text="Capacity:" />
                                        <TextField fx:id="capacityField" promptText="50" styleClass="user-input" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-form-label" text="Venue Type:" />
                                        <ComboBox fx:id="venueTypeFilterComboBox" styleClass="user-combo" maxWidth="9999" />
                                    </VBox>
                                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                                        <Label styleClass="user-form-label" text="City:" />
                                        <ComboBox fx:id="cityFilterComboBox" styleClass="user-combo" maxWidth="9999" />
                                    </VBox>
                                </HBox>

                                <VBox spacing="5">
                                    <Label styleClass="user-form-label" text="Venue:" />
                                    <ComboBox fx:id="venueComboBox" styleClass="user-combo" maxWidth="9999" />
                                </VBox>

                                <VBox spacing="5">
                                    <Label styleClass="user-form-label" text="Description:" />
                                    <TextArea fx:id="descriptionArea" prefRowCount="4"
                                              promptText="Enter event description"
                                              styleClass="user-textarea" />
                                </VBox>

                                <Button fx:id="submitRequestButton" onAction="#submitCustomRequest"
                                        text="Submit Request"
                                        style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 13px; -fx-padding: 10 24; -fx-background-radius: 10; -fx-border-color: transparent; -fx-border-width: 0; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 8, 0, 0, 3);" />

                                <Label styleClass="user-section-title" text="My Pending Requests" />
                                <TableView fx:id="myRequestsTable" prefHeight="180" styleClass="user-table">
                                    <columns>
                                        <TableColumn fx:id="reqTypeColumn"     text="Event Type"   prefWidth="120" />
                                        <TableColumn fx:id="reqDateColumn"     text="Event Date"   prefWidth="110" />
                                        <TableColumn fx:id="reqBudgetColumn"   text="Budget (TND)" prefWidth="110" />
                                        <TableColumn fx:id="reqCapacityColumn" text="Capacity"     prefWidth="90"  />
                                        <TableColumn fx:id="reqLocationColumn" text="Location"     prefWidth="150" />
                                        <TableColumn fx:id="reqStatusColumn"   text="Status"       prefWidth="100" />
                                        <TableColumn fx:id="reqCreatedColumn"  text="Submitted On" prefWidth="120" />
                                    </columns>
                                </TableView>
                            </VBox>

                            <!-- PAGE: Profile -->
                            <VBox fx:id="userPageProfile" spacing="16" visible="false" managed="false"
                                  style="-fx-background-color: transparent; -fx-padding: 16 24 24 24;">
                                <Label styleClass="user-section-title" text="My Profile" />

                                <VBox spacing="14" styleClass="user-card">
                                    <Label styleClass="user-form-label" text="Personal Information" />
                                    <HBox spacing="14">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="First Name:" />
                                            <TextField fx:id="firstNameField" promptText="First Name" styleClass="user-input" />
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Last Name:" />
                                            <TextField fx:id="lastNameField" promptText="Last Name" styleClass="user-input" />
                                        </VBox>
                                    </HBox>
                                    <HBox spacing="14">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Email:" />
                                            <TextField fx:id="emailField" promptText="Email" styleClass="user-input" />
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Phone:" />
                                            <TextField fx:id="phoneField" promptText="Phone" styleClass="user-input" />
                                        </VBox>
                                    </HBox>
                                    <VBox spacing="5">
                                        <Label styleClass="user-form-label" text="Address:" />
                                        <TextField fx:id="addressField" promptText="Address" styleClass="user-input" />
                                    </VBox>
                                    <Button onAction="#updateProfile" styleClass="user-btn-apply" text="Update Profile" />
                                </VBox>

                                <VBox spacing="14" styleClass="user-card">
                                    <Label styleClass="user-form-label" text="Event Preferences" />
                                    <HBox spacing="14">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Favorite Categories:" />
                                            <TextField fx:id="preferredCategoriesCombo" promptText="e.g. Partying,Formation" styleClass="user-input" />
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Favorite Locations:" />
                                            <TextField fx:id="preferredLocationsCombo" promptText="e.g. Tunis,Sfax" styleClass="user-input" />
                                        </VBox>
                                    </HBox>
                                    <HBox spacing="14">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Max Price (TND):" />
                                            <TextField fx:id="maxPriceField" promptText="Max Price" styleClass="user-input" />
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label styleClass="user-form-label" text="Minimum Rating:" />
                                            <ComboBox fx:id="minRatingCombo" styleClass="user-combo" maxWidth="9999" />
                                        </VBox>
                                    </HBox>
                                    <Button onAction="#savePreferences" styleClass="user-btn-apply" text="Save Preferences" />
                                </VBox>
                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

        </HBox>
    </VBox>

    <!-- OVERLAY DIALOG (from remote) -->
    <StackPane fx:id="eventDialogPane" managed="true" StackPane.alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.45);" visible="false">
        <VBox maxHeight="580" prefWidth="520" spacing="0"
              style="-fx-background-color: white; -fx-border-radius: 14; -fx-background-radius: 14;
                     -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.28), 24, 0, 0, 8);">

            <!-- Green header bar -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-background-color: #059669; -fx-padding: 16 22;
                         -fx-background-radius: 13 13 0 0;">
                <Label fx:id="dialogEventTitle" text="Event Details"
                       style="-fx-font-size: 17; -fx-font-weight: bold; -fx-text-fill: white;" />
            </HBox>

            <!-- Event info section -->
            <VBox spacing="14" style="-fx-padding: 20 22 16 22;">

                <!-- Type + Status badge chips -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="dialogEventType" text="-"
                           style="-fx-background-color: #ecfdf5; -fx-border-color: #a7f3d0; -fx-border-width: 1;
                                  -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 4 14;
                                  -fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #065f46;" />
                    <Label fx:id="dialogEventStatus" text="-"
                           style="-fx-background-color: #eff6ff; -fx-border-color: #bfdbfe; -fx-border-width: 1;
                                  -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 4 14;
                                  -fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #1e40af;" />
                </HBox>

                <!-- Date + Location side-by-side -->
                <HBox spacing="40">
                    <VBox spacing="3">
                        <Label text="📅  DATE"
                               style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #9ca3af;" />
                        <Label fx:id="dialogEventDate" text="-"
                               style="-fx-font-size: 13; -fx-text-fill: #1f2937;" />
                    </VBox>
                    <VBox spacing="3">
                        <Label text="📍  LOCATION"
                               style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #9ca3af;" />
                        <Label fx:id="dialogEventLocation" text="-"
                               style="-fx-font-size: 13; -fx-text-fill: #1f2937;" />
                    </VBox>
                </HBox>

                <!-- Price chip -->
                <VBox spacing="3"
                      style="-fx-background-color: #fff7ed; -fx-border-color: #fed7aa; -fx-border-width: 1;
                             -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 16;
                             -fx-max-width: 200;">
                    <Label text="💰  PRICE PER PERSON"
                           style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #9a3412;" />
                    <Label fx:id="dialogEventPrice" text="-"
                           style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ea580c;" />
                </VBox>

                <!-- Description -->
                <VBox spacing="4">
                    <Label text="📝  DESCRIPTION"
                           style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #9ca3af;" />
                    <TextArea fx:id="dialogEventDescription" editable="false" prefRowCount="2"
                              style="-fx-font-size: 12; -fx-text-fill: #4b5563;
                                     -fx-background-color: #f9fafb; -fx-border-color: #e5e7eb;
                                     -fx-border-radius: 6; -fx-background-radius: 6;" />
                </VBox>
            </VBox>

            <Separator />

            <!-- Booking section -->
            <VBox spacing="12" style="-fx-padding: 16 22 22 22;">
                <Label text="🎯  Booking Details"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #065f46;" />

                <!-- Headcount + Coupon + Preview -->
                <HBox spacing="12" alignment="BOTTOM_LEFT">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Headcount (persons)"
                                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;" />
                            <Label text="ℹ"
                                   style="-fx-font-size: 11; -fx-text-fill: #9ca3af; -fx-cursor: hand;">
                                <tooltip>
                                    <Tooltip text="Number of participants. The total price will update accordingly." wrapText="true" prefWidth="210" />
                                </tooltip>
                            </Label>
                        </HBox>
                        <TextField fx:id="dialogHeadcountField" promptText="e.g. 10"
                                   style="-fx-font-size: 13; -fx-padding: 7 10; -fx-border-color: #d1d5db;
                                          -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Coupon Code"
                                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;" />
                            <Label text="ℹ"
                                   style="-fx-font-size: 11; -fx-text-fill: #9ca3af; -fx-cursor: hand;">
                                <tooltip>
                                    <Tooltip text="Enter a valid promo code to receive a discount on your booking." wrapText="true" prefWidth="210" />
                                </tooltip>
                            </Label>
                        </HBox>
                        <TextField fx:id="dialogCouponCodeField" promptText="e.g. WELCOME10"
                                   style="-fx-font-size: 13; -fx-padding: 7 10; -fx-border-color: #d1d5db;
                                          -fx-border-radius: 6; -fx-background-radius: 6;" />
                    </VBox>
                    <Button onAction="#applyDialogCoupon" text="Preview Price"
                            style="-fx-background-color: #374151; -fx-text-fill: white;
                                   -fx-padding: 9 16; -fx-border-radius: 6; -fx-background-radius: 6;
                                   -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 12;" />
                </HBox>

                <!-- Price breakdown box -->
                <Label fx:id="dialogPricingBreakdown" text="" wrapText="true"
                       style="-fx-font-family: 'Monospace'; -fx-font-size: 11; -fx-text-fill: #374151;
                              -fx-background-color: #f0fdf4; -fx-border-color: #a7f3d0; -fx-border-width: 1;
                              -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10;" />

                <!-- CTA buttons -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button onAction="#closeEventDialog" text="Cancel"
                            style="-fx-background-color: transparent; -fx-text-fill: #6b7280;
                                   -fx-padding: 10 22; -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-border-color: #d1d5db; -fx-border-width: 1;
                                   -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13;" />
                    <Button onAction="#confirmBooking" text="✓  Confirm Booking"
                            style="-fx-background-color: #059669; -fx-text-fill: white;
                                   -fx-padding: 11 26; -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;
                                   -fx-effect: dropshadow(three-pass-box, rgba(5,150,105,0.4), 8, 0, 0, 3);" />
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
         <StackPane fx:id="reviewDialogPane" visible="false" managed="true"
                   StackPane.alignment="CENTER"
                   style="-fx-background-color: rgba(0,0,0,0.45);">
            <VBox maxHeight="400" prefWidth="400" spacing="14" styleClass="dialog-card">
                <Label fx:id="reviewDialogTitle" styleClass="dialog-title" text="Leave a Review" />
                <Separator />
                <Label styleClass="top-muted" text="Rating (1-5):" />
                <ComboBox fx:id="reviewRatingCombo" styleClass="combo-web" />
                <Label styleClass="top-muted" text="Comment:" />
                <TextArea fx:id="reviewCommentArea" prefRowCount="4"
                          promptText="Share your experience..."
                          styleClass="textarea-web" />
                <HBox alignment="CENTER" spacing="15">
                    <Button onAction="#submitReview" styleClass="btn-success" text="Submit Review" />
                    <Button onAction="#closeReviewDialog" styleClass="btn-ghost" text="Cancel" />
                </HBox>
            </VBox>
        </StackPane>


</StackPane>
