<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.synapseevent.controller.PartyingController"
    styleClass="page-wrap"
    style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #f8fafc 0%, #eff6ff 100%);">

    <!-- ── TOP HEADER ── -->
    <top>
        <VBox
            style="-fx-background-color: linear-gradient(to bottom, #1e40af 0%, #1e3a8a 100%);
                   -fx-padding: 20 28;
                   -fx-border-color: rgba(255,255,255,0.10);
                   -fx-border-width: 0 0 1 0;"
            spacing="4">
            <Label text="🎉 Partying Events Management"
                style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: 700;
                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
            <Label text="Create and manage amazing party events"
                style="-fx-text-fill: rgba(255,255,255,0.72); -fx-font-size: 13;
                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
        </VBox>
    </top>

    <!-- ── CENTER SPLIT ── -->
    <center>
        <SplitPane dividerPositions="0.40"
            style="-fx-padding: 14; -fx-background-color: transparent; -fx-border-color: transparent;">

            <!-- ════ LEFT PANEL — Form ════ -->
            <ScrollPane fitToHeight="true" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: transparent;
                       -fx-border-color: transparent;">
                <VBox spacing="14" style="-fx-padding: 4 8 8 4;">

                    <!-- Form Header card -->
                    <VBox spacing="4"
                        style="-fx-background-color: rgba(255,255,255,0.80);
                               -fx-padding: 14 16;
                               -fx-background-radius: 14; -fx-border-radius: 14;
                               -fx-border-color: transparent; -fx-border-width: 0;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 8, 0, 0, 2);">
                        <Label text="Create / Edit Partying Event"
                            style="-fx-font-size: 16; -fx-font-weight: 700;
                                   -fx-text-fill: #1e40af;
                                   -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                        <Label text="Fill in the details below to create an unforgettable party event"
                            style="-fx-font-size: 12; -fx-text-fill: #475569;
                                   -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                    </VBox>

                    <!-- ── Party Details ── -->
                    <VBox spacing="10"
                        style="-fx-background-color: rgba(255,255,255,0.75);
                               -fx-padding: 14 16;
                               -fx-background-radius: 14; -fx-border-radius: 14;
                               -fx-border-color: transparent;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <Label text="🎊  Party Details"
                            style="-fx-font-size: 13; -fx-font-weight: 700;
                                   -fx-text-fill: #1e40af;
                                   -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                        <GridPane hgap="14" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="65" />
                            </columnConstraints>

                            <Label text="Event Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <TextField fx:id="nameField" promptText="Enter party event name"
                                GridPane.rowIndex="0" GridPane.columnIndex="1"
                                styleClass="user-input"
                                style="-fx-pref-height: 36;" />

                            <Label text="Theme:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="themeComboBox" promptText="Select party theme"
                                GridPane.rowIndex="1" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />

                            <Label text="Music Type:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="musicTypeComboBox" promptText="Select music type"
                                GridPane.rowIndex="2" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />

                            <Label text="Description:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <TextArea fx:id="descriptionField" wrapText="true" prefRowCount="2"
                                promptText="Describe your event..."
                                GridPane.rowIndex="3" GridPane.columnIndex="1"
                                styleClass="user-textarea" />

                            <Label text="Status:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="statusComboBox"
                                GridPane.rowIndex="4" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />
                        </GridPane>
                    </VBox>

                    <!-- ── Schedule & Venue ── -->
                    <VBox spacing="10"
                        style="-fx-background-color: rgba(255,255,255,0.75);
                               -fx-padding: 14 16;
                               -fx-background-radius: 14; -fx-border-radius: 14;
                               -fx-border-color: transparent;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <Label text="📅  Schedule &amp; Venue"
                            style="-fx-font-size: 13; -fx-font-weight: 700;
                                   -fx-text-fill: #1e40af;
                                   -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                        <GridPane hgap="14" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="65" />
                            </columnConstraints>

                            <Label text="Date:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <DatePicker fx:id="datePicker" promptText="Select date"
                                GridPane.rowIndex="0" GridPane.columnIndex="1"
                                styleClass="user-datepicker"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />

                            <Label text="Start Time:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="startTimeComboBox" promptText="Select start time"
                                GridPane.rowIndex="1" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />

                            <Label text="End Time:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="endTimeComboBox" promptText="Select end time"
                                GridPane.rowIndex="2" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />

                            <Label text="Venue Type:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="venueTypeFilterComboBox"
                                GridPane.rowIndex="3" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />

                            <Label text="Venue:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <ComboBox fx:id="venueComboBox" promptText="Select venue"
                                GridPane.rowIndex="4" GridPane.columnIndex="1"
                                styleClass="user-combo"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />
                        </GridPane>
                    </VBox>

                    <!-- ── Pricing & Capacity ── -->
                    <VBox spacing="10"
                        style="-fx-background-color: rgba(255,255,255,0.75);
                               -fx-padding: 14 16;
                               -fx-background-radius: 14; -fx-border-radius: 14;
                               -fx-border-color: transparent;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <Label text="💰  Pricing &amp; Capacity"
                            style="-fx-font-size: 13; -fx-font-weight: 700;
                                   -fx-text-fill: #1e40af;
                                   -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                        <GridPane hgap="14" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="65" />
                            </columnConstraints>

                            <Label text="Capacity:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <TextField fx:id="capacityField" promptText="Number of guests"
                                GridPane.rowIndex="0" GridPane.columnIndex="1"
                                styleClass="user-input"
                                style="-fx-pref-height: 36;" />

                            <Label text="Price (TND):" GridPane.rowIndex="1" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <TextField fx:id="priceField" promptText="Ticket price"
                                GridPane.rowIndex="1" GridPane.columnIndex="1"
                                styleClass="user-input"
                                style="-fx-pref-height: 36;" />

                            <Label text="Min Age:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <TextField fx:id="ageRestrictionField" promptText="Minimum age requirement"
                                GridPane.rowIndex="2" GridPane.columnIndex="1"
                                styleClass="user-input"
                                style="-fx-pref-height: 36;" />

                            <Label text="Catering:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <CheckBox fx:id="cateringCheckBox" text="Includes catering"
                                GridPane.rowIndex="3" GridPane.columnIndex="1"
                                style="-fx-text-fill: #1e293b; -fx-font-size: 12;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                        </GridPane>
                    </VBox>

                    <!-- ── Filters ── -->
                    <VBox spacing="10"
                        style="-fx-background-color: rgba(255,255,255,0.75);
                               -fx-padding: 14 16;
                               -fx-background-radius: 14; -fx-border-radius: 14;
                               -fx-border-color: transparent;
                               -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                        <Label text="🔍  Filters"
                            style="-fx-font-size: 13; -fx-font-weight: 700;
                                   -fx-text-fill: #1e40af;
                                   -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                        <GridPane hgap="14" vgap="10">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="35" />
                                <ColumnConstraints percentWidth="65" />
                            </columnConstraints>
                            <Label text="Filter by Date:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                                style="-fx-font-weight: 600; -fx-font-size: 12; -fx-text-fill: #1e40af;
                                       -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                            <DatePicker fx:id="filterDatePicker" promptText="Select filter date"
                                GridPane.rowIndex="0" GridPane.columnIndex="1"
                                styleClass="user-datepicker"
                                style="-fx-pref-height: 36; -fx-max-width: 9999;" />
                        </GridPane>
                    </VBox>

                    <!-- ── Action Buttons ── -->
                    <HBox spacing="8" style="-fx-padding: 6 0 2 0;">
                        <Button text="➕ Add Event" onAction="#addPartyingEvent"
                            styleClass="btn-primary-sm"
                            style="-fx-padding: 10 18; -fx-font-size: 12;" />
                        <Button text="✏️ Update" onAction="#updatePartyingEvent"
                            styleClass="btn-success-sm"
                            style="-fx-padding: 10 18; -fx-font-size: 12;" />
                        <Button text="🗑️ Delete" onAction="#deletePartyingEvent"
                            styleClass="btn-danger-sm"
                            style="-fx-padding: 10 18; -fx-font-size: 12;" />
                        <Button text="🔄 Clear" onAction="#clearFields"
                            styleClass="btn-ghost-sm"
                            style="-fx-padding: 10 18; -fx-font-size: 12;" />
                    </HBox>

                </VBox>
            </ScrollPane>

            <!-- ════ RIGHT PANEL — Table ════ -->
            <VBox spacing="12" style="-fx-padding: 4 4 4 8;">

                <!-- Table header card -->
                <VBox spacing="4"
                    style="-fx-background-color: linear-gradient(to bottom, #1e40af 0%, #1e3a8a 100%);
                           -fx-padding: 14 16;
                           -fx-background-radius: 14; -fx-border-radius: 14;
                           -fx-border-color: transparent;
                           -fx-effect: dropshadow(gaussian, rgba(30,58,138,0.35), 10, 0, 0, 3);">
                    <Label text="🎊  Partying Events List"
                        style="-fx-font-size: 16; -fx-font-weight: 700; -fx-text-fill: white;
                               -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                    <Label text="Click on an event to edit its details"
                        style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.72);
                               -fx-font-family: 'Segoe UI', 'Inter', sans-serif;" />
                </VBox>

                <!-- Table -->
                <TableView fx:id="partyingTable" onMouseClicked="#selectPartyingEvent"
                    styleClass="user-table"
                    VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn"       text="ID"       prefWidth="50"  />
                        <TableColumn fx:id="nameColumn"     text="Name"     prefWidth="150" />
                        <TableColumn fx:id="dateColumn"     text="Date"     prefWidth="100" />
                        <TableColumn fx:id="venueColumn"    text="Venue"    prefWidth="120" />
                        <TableColumn fx:id="capacityColumn" text="Capacity" prefWidth="80"  />
                        <TableColumn fx:id="priceColumn"    text="Price"    prefWidth="80"  />
                        <TableColumn fx:id="statusColumn"   text="Status"   prefWidth="100" />
                    </columns>
                </TableView>

                <!-- Quick action buttons -->
                <HBox spacing="8" style="-fx-padding: 2 0 0 0;">
                    <Button text="📤 Publish" onAction="#publishEvent"
                        styleClass="btn-primary-sm"
                        style="-fx-padding: 9 16; -fx-font-size: 12;" />
                    <Button text="📝 Save Draft" onAction="#saveAsDraft"
                        style="-fx-padding: 9 16; -fx-font-size: 12; -fx-font-weight: 700;
                               -fx-background-color: #d97706; -fx-text-fill: white;
                               -fx-background-radius: 8; -fx-border-radius: 8; -fx-cursor: hand;" />
                    <Button text="🎵 Filter by Venue" onAction="#filterByVenueType"
                        styleClass="btn-ghost-sm"
                        style="-fx-padding: 9 16; -fx-font-size: 12;" />
                    <Button text="📅 Filter by Date" onAction="#filterByDate"
                        styleClass="btn-ghost-sm"
                        style="-fx-padding: 9 16; -fx-font-size: 12;" />
                </HBox>

            </VBox>
        </SplitPane>
    </center>

</BorderPane>