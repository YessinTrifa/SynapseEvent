<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="root" styleClass="root" stylesheets="@../css/auth.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.synapseevent.controller.LandingController">

   <!-- HEADER -->
   <top>
      <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: transparent;" styleClass="web-header">

                     <Region style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS" />

                     <Button onAction="#goToLogin" styleClass="btn-ghost" text="Login" />
         <Button onAction="#goToRegister" styleClass="btn-primary" text="Get started" />
      </HBox>
   </top>

   <!-- HERO -->
   <center>
      <HBox alignment="CENTER" fillHeight="true">
      <HBox alignment="CENTER" spacing="40" styleClass="hero-wrap">
         <!-- left text -->
         <VBox spacing="14" styleClass="hero-left" HBox.hgrow="ALWAYS">
               <HBox alignment="CENTER_LEFT" spacing="10" />
               <HBox prefHeight="100.0" prefWidth="200.0">
                  <children>
                     <ImageView fitHeight="123.0" fitWidth="95.0" preserveRatio="true" styleClass="logo">
                        <image>
                           <Image url="@../images/logo.png" />
                        </image>
                     </ImageView>
                     <Label prefHeight="126.0" prefWidth="332.0" styleClass="web-logo-text" text="SynapseEvent">
                        <font>
                           <Font size="21.0" />
                        </font>
                     </Label>
                  </children>
               </HBox>
            <Label styleClass="hero-kicker" text="Event management, simplified" />
            <Label styleClass="hero-title" text="Plan events your team actually enjoys." wrapText="true" />
            <Label styleClass="hero-subtitle" text="Create events, manage guests, book venues, and track feedback  all in one clean workflow." wrapText="true" />
            <Button onAction="#goToRegister" styleClass="btn-primary" text="Get started →" />
         </VBox>
         <!-- right illustration -->
         <VBox fx:id="heroCard" alignment="CENTER_RIGHT" styleClass="hero-right">
            <ImageView fitWidth="520" preserveRatio="true" styleClass="hero-illustration">
               <image>
                  <Image url="@../images/meeting.png" />
               </image>
            </ImageView>
         </VBox>
      </HBox>
      </HBox>
   </center>

</BorderPane>
