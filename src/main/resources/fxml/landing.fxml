<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="rootPane" styleClass="landing-root" stylesheets="@../css/landing.css"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.synapseevent.controller.LandingController">

    <!-- BACKGROUND IMAGE -->
    <ImageView fx:id="bgImage" preserveRatio="false" smooth="true"
               fitWidth="1280" fitHeight="800"

               StackPane.alignment="CENTER"
        >
        <image>
            <Image url="@../images/back-landing.png" />
        </image>
    </ImageView>

    <!-- DARK OVERLAY for text readability -->
    <!-- LIGHT OVERLAY for text readability -->
    <StackPane style="-fx-background-color: rgba(255,255,255,0.55);" mouseTransparent="true" />

    <BorderPane style="-fx-background-color: transparent;">

        <!-- TOP BAR -->
        <top>
            <HBox alignment="CENTER_LEFT" styleClass="landing-topbar">
                <!-- Logo -->
                <ImageView fitHeight="72.0" fitWidth="180.0" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                </ImageView>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Login button -->
                <Button onAction="#goToLogin" styleClass="pill-button" text="Log In" />
            </HBox>
        </top>

        <!-- CENTER CONTENT -->
        <center>
            <VBox alignment="CENTER" spacing="24" style="-fx-padding: 0 40;">

                <!-- Brand name -->
                <Label styleClass="brand-title" text="Synapse Event" />

                <Region prefHeight="16" />

                <!-- Tagline / value proposition -->
                <Label styleClass="tagline" text="Professional Event Management – Simplified" />

                <Region prefHeight="40" />

                <!-- Subtitle / benefit -->
                <Label styleClass="subtitle"
                       text="Plan, promote, manage, and analyze your events with powerful yet simple tools"
                       wrapText="true"
                       maxWidth="620" />

                <Region prefHeight="64" />

                <!-- Primary CTA -->
                <Button onAction="#goToRegister" styleClass="primary-button" text="Get Started Free" />

                <Region prefHeight="24" />

                <!-- Trust / secondary text -->
                <Label styleClass="trust-text"
                       text="No credit card required • Trusted by event organizers worldwide" />

                <!-- Optional small space before potential future content -->
                <Region prefHeight="120" />

            </VBox>
        </center>

    </BorderPane>
</StackPane>